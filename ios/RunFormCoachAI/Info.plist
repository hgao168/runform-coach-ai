<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSCameraUsageDescription</key>
    <string>Record your running form with live framing guidance for accurate analysis.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Select a short running video for form analysis.</string>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>$(GOOGLE_REVERSED_CLIENT_ID)</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>$(GOOGLE_REVERSED_CLIENT_ID)</string>
            </array>
        </dict>
        <dict>
            <key>CFBundleURLName</key>
            <string>runformcoachai.strava.callback</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>runformcoachai</string>
            </array>
        </dict>
    </array>
    <key>BACKEND_BASE_URL</key>
    <string>$(BACKEND_BASE_URL)</string>
    <key>STRAVA_BACKEND_BASE_URL</key>
    <string>$(STRAVA_BACKEND_BASE_URL)</string>
    <key>GOOGLE_IOS_CLIENT_ID</key>
    <string>$(GOOGLE_IOS_CLIENT_ID)</string>
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <key>NSMotionUsageDescription</key>
    <string>Collect motion data (accelerometer, gyroscope) in real time during your run to analyze cadence, stride, and running form.</string>
    <key>NSHealthShareUsageDescription</key>
    <string>Sync your running workouts, cadence, heart rate, and distance data with Apple Health.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>Save your completed runs and running form metrics to Apple Health for a complete picture of your fitness.</string>
</dict>
</plist>
