/* app.wxss — Global styles */

page {
  background-color: #0a0a0f;
  color: #ffffff;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* ── Containers ── */
.page-container {
  min-height: 100vh;
  background: #0a0a0f;
  padding: 20rpx 28rpx 48rpx;
  box-sizing: border-box;
}

/* ── Cards ── */
.card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.card-dark {
  background: rgba(0, 0, 0, 0.28);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

/* ── Typography ── */
.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.62);
  margin-top: 6rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 18rpx;
}

.label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 10rpx;
}

.body-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.78);
  line-height: 1.6;
}

.caption {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.54);
  line-height: 1.5;
}

/* ── Buttons ── */
.btn-primary {
  width: 100%;
  height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #00f5a0, #00d4ff);
  color: #000000;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-sizing: border-box;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  width: 100%;
  height: 88rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.82);
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-sizing: border-box;
}

.btn-secondary::after {
  border: none;
}

.btn-mint-outline {
  width: 100%;
  height: 88rpx;
  border-radius: 24rpx;
  background: rgba(0, 245, 160, 0.12);
  color: #00f5a0;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(0, 245, 160, 0.4);
  box-sizing: border-box;
}

.btn-mint-outline::after {
  border: none;
}

/* ── Accent colors ── */
.text-mint   { color: #00f5a0; }
.text-cyan   { color: #00d4ff; }
.text-orange { color: #ff9f30; }
.text-white  { color: #ffffff; }
.text-dim    { color: rgba(255, 255, 255, 0.54); }

/* ── Score pill ── */
.severity-pill {
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.82);
}

/* ── Divider ── */
.divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.08);
  margin: 20rpx 0;
}

/* ── Input field ── */
.input-field {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

/* ── Progress bar ── */
.progress-track {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #00f5a0, #00d4ff);
}

/* ── Loading ── */
.loading-overlay {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.62);
}

/* ── Empty state ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  gap: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.62);
  text-align: center;
}

.empty-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.38);
  text-align: center;
  line-height: 1.6;
}
