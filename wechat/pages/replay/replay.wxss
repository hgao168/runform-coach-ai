/* pages/replay/replay.wxss */

.page-container {
  padding: 0 28rpx 40rpx;
  min-height: 100vh;
}

/* ── Header ── */

.replay-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 24rpx 0 20rpx 0;
  gap: 8rpx;
}

.back-btn {
  font-size: 28rpx;
  color: #00f5a0;
  font-weight: 500;
}

.replay-title {
  font-size: 38rpx;
  font-weight: 800;
  color: rgba(255,255,255,0.92);
}

.replay-date {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
}

/* ── Stats Grid ── */

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.stat-card {
  flex: 1 1 calc(50% - 8rpx);
  min-width: calc(50% - 8rpx);
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  box-sizing: border-box;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
}

.stat-accent-green {
  color: #00f5a0;
}

.stat-accent-cyan {
  color: #00d4ff;
}

.stat-accent-orange {
  color: #ff9f30;
}

/* ── Section ── */

.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.section-icon {
  font-size: 28rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.8);
}

/* ── Trend Chart ── */

.trend-canvas-wrap {
  position: relative;
  width: 100%;
  height: 380rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  overflow: hidden;
}

.trend-canvas {
  width: 100%;
  height: 100%;
}

.trend-tooltip {
  position: absolute;
  pointer-events: none;
  z-index: 10;
  transform: translate(-50%, -100%);
}

.trend-tooltip-inner {
  background: rgba(10,10,15,0.94);
  border: 1rpx solid;
  border-radius: 12rpx;
  padding: 10rpx 20rpx;
  white-space: nowrap;
}

.trend-tooltip-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
}

.trend-tap-hint {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: rgba(255,255,255,0.28);
  margin-top: 10rpx;
}

.trend-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  gap: 12rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
}

.trend-empty-icon {
  font-size: 48rpx;
}

.trend-empty-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.42);
}

/* ── Path Canvas ── */

.path-canvas-wrap {
  width: 100%;
  height: 360rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  overflow: hidden;
}

.path-canvas {
  width: 100%;
  height: 100%;
}

.path-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  gap: 8rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
}

.path-empty-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.36);
}

/* ── Action ── */

.action-section {
  margin-top: 32rpx;
}

.full-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-mint-outline {
  background: rgba(0, 245, 160, 0.1);
  border: 1rpx solid rgba(0, 245, 160, 0.35);
  color: #00f5a0;
}
