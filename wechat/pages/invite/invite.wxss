/* pages/invite/invite.wxss */
.invite-page {
  min-height: 100vh;
  background: #0a0a0f;
  padding: 24rpx 32rpx;
}

.invite-header {
  text-align: center;
  padding: 40rpx 0 32rpx;
}

.invite-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.invite-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
}

/* Code Card */
.code-card {
  background: linear-gradient(135deg, #12121a 0%, #1a1a2e 100%);
  border: 1rpx solid rgba(0,245,160,0.15);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.code-label {
  font-size: 26rpx;
  color: rgba(0,245,160,0.7);
  margin-bottom: 16rpx;
}

.code-display {
  background: rgba(0,245,160,0.08);
  border: 2rpx dashed rgba(0,245,160,0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
}

.code-text {
  font-size: 48rpx;
  font-weight: 800;
  font-family: monospace;
  color: #00f5a0;
  letter-spacing: 8rpx;
}

.code-actions {
  display: flex;
  gap: 16rpx;
}

.btn-copy, .btn-share {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0;
}

.btn-copy {
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.8);
}

.btn-copy::after {
  border: none;
}

.btn-share {
  background: #00f5a0;
  color: #0a0a0f;
}

.btn-share::after {
  border: none;
}

/* Reward hint */
.reward-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 0 32rpx;
}

.reward-icon {
  font-size: 36rpx;
}

.reward-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
}

/* Invited section */
.invited-section {
  margin-top: 8rpx;
}

.section-header {
  padding: 16rpx 0 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.invited-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.invitee-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
}

.invitee-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(0,245,160,0.15);
  color: #00f5a0;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.invitee-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.invitee-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.invitee-date {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
}

.invitee-status {
  font-size: 28rpx;
  color: #00f5a0;
  font-weight: 700;
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 8rpx;
}

.empty-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
}
