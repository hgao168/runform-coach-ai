/* pages/plan/plan.wxss */

.header-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 24rpx;
}

.icon-bubble {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(0,245,160,0.18), rgba(0,212,255,0.18));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.header-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.form-section {
  margin-bottom: 32rpx;
}

.label-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.label-note {
  font-size: 26rpx;
}

.km-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.km-slider {
  flex: 1;
}

.km-badge {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 4rpx;
  width: 100rpx;
  justify-content: flex-end;
}

.km-num {
  font-size: 36rpx;
  font-weight: 700;
}

.km-unit {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

.chip-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.chip {
  padding: 12rpx 24rpx;
  border-radius: 14rpx;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
  font-size: 26rpx;
  color: rgba(255,255,255,0.72);
  transition: all 0.2s;
}

.chip-active {
  background: rgba(0,245,160,0.18);
  border-color: rgba(0,245,160,0.5);
  color: #00f5a0;
  font-weight: 700;
}

.day-chip {
  min-width: 76rpx;
  text-align: center;
  padding: 12rpx 18rpx;
}

.mode-chip {
  min-width: 108rpx;
  text-align: center;
}

.injury-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0;
}

.injury-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-right: 20rpx;
}

.loading-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(0,0,0,0.3);
  border-top-color: #000000;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.full-btn {
  width: 100%;
  height: 96rpx;
  font-size: 30rpx;
  border-radius: 28rpx;
}

.plan-summary-row {
  display: flex;
  flex-direction: row;
  gap: 32rpx;
  margin-top: 16rpx;
}

.plan-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.plan-stat-num {
  font-size: 60rpx;
  font-weight: 800;
  line-height: 1;
}

.plan-stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.56);
}

.day-card {
  background: rgba(255,255,255,0.05);
  border-radius: 20rpx;
  padding: 24rpx 24rpx 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.day-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.day-tag {
  padding: 6rpx 18rpx;
  border-radius: 10rpx;
  border: 1rpx solid transparent;
}

.day-type {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
}

.day-km {
  font-size: 28rpx;
  font-weight: 700;
}

.day-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.68);
  line-height: 1.6;
}

.day-notes {
  margin-top: 10rpx;
  padding: 10rpx 16rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 10rpx;
}

/* ===== MARATHON / RACE PLAN STYLES ===== */

.marathon-plan-section {
  margin-top: 24rpx;
}

.marathon-meta {
  margin-top: 10rpx;
  margin-bottom: 6rpx;
}

.marathon-meta-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #00f5a0;
}

.marathon-sub-text {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  line-height: 1.5;
  margin-top: 4rpx;
}

/* Phase block */
.phase-block {
  margin-bottom: 24rpx;
}

/* Phase header (like Base Phase W1-W4) */
.phase-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx;
  margin-bottom: 12rpx;
  background: linear-gradient(135deg, rgba(0,245,160,0.12), rgba(0,212,255,0.08));
  border-radius: 16rpx;
  border-left: 4rpx solid #00f5a0;
}

.phase-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #00f5a0;
}

.phase-range {
  font-size: 24rpx;
  color: rgba(255,255,255,0.56);
  font-weight: 600;
}

/* Marathon week card */
.marathon-week-card {
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.marathon-week-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.marathon-week-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  flex-shrink: 0;
}

.marathon-week-stats {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.marathon-stat {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2rpx;
}

.marathon-stat-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.45);
  text-transform: uppercase;
}

.marathon-stat-value {
  font-size: 24rpx;
  font-weight: 700;
}

.race-week-badge {
  padding: 4rpx 14rpx;
  background: rgba(255,159,48,0.18);
  border: 1rpx solid rgba(255,159,48,0.4);
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #ff9f30;
  align-self: center;
}

/* Key workout row */
.key-workout-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: rgba(0,245,160,0.06);
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}

.key-workout-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #00f5a0;
  white-space: nowrap;
}

.key-workout-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.78);
  line-height: 1.5;
}

/* Daily workouts section */
.marathon-workouts {
  border-top: 1rpx solid rgba(255,255,255,0.06);
  padding-top: 12rpx;
}

.workouts-section-title {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.5);
  margin-bottom: 10rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.workout-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12rpx;
  padding: 10rpx 12rpx;
  margin-bottom: 6rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 10rpx;
}

.workout-day-tag {
  flex-shrink: 0;
  width: 60rpx;
  padding: 4rpx 0;
  background: rgba(0,245,160,0.12);
  border-radius: 8rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #00f5a0;
}

.workout-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.workout-title {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
}

.workout-km {
  font-size: 22rpx;
  font-weight: 700;
  color: #00f5a0;
}

.workout-details {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  line-height: 1.5;
}
