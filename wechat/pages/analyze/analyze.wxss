/* pages/analyze/analyze.wxss */

/* Injury Prevention Banner */
.injury-prevention-banner {
  background: linear-gradient(135deg, rgba(255, 71, 87, 0.12), rgba(255, 159, 48, 0.1));
  border: 2rpx solid rgba(255, 71, 87, 0.25);
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
}

.injury-banner-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff9f30;
  line-height: 1.5;
  display: block;
  text-align: center;
}

.header-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 24rpx;
}

.icon-bubble {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(0,245,160,0.18), rgba(0,212,255,0.18));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.header-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.guide-tips {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.tip-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.tip-icon {
  font-size: 32rpx;
  width: 40rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.72);
  line-height: 1.5;
}

.video-area {
  width: 100%;
  height: 360rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.04);
  border: 2rpx dashed rgba(255,255,255,0.18);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.video-placeholder-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.video-placeholder-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #00f5a0;
}

.video-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.video-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 20rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
}

.video-overlay-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
}

.video-overlay-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.62);
  margin-top: 4rpx;
  display: block;
}

.action-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.pick-btn {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
}

.analyze-btn {
  flex: 2;
  height: 88rpx;
  font-size: 28rpx;
}

.loading-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(0,0,0,0.3);
  border-top-color: #000000;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.progress-card {
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-top: -8rpx;
  margin-bottom: 24rpx;
}

.progress-label-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

/* RF-308: Angle selection */
.angle-card {
  padding: 28rpx 32rpx;
}

.angle-chips {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  flex-wrap: wrap;
}

.angle-chip {
  flex: 1;
  min-width: 180rpx;
  padding: 24rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.angle-chip-active {
  background: rgba(0, 245, 160, 0.12);
  border-color: rgba(0, 245, 160, 0.5);
  box-shadow: 0 0 20rpx rgba(0, 245, 160, 0.08);
}

.angle-chip-icon {
  font-size: 48rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.angle-chip-label {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.9);
}

.angle-chip-active .angle-chip-label {
  color: #00f5a0;
}

.angle-chip-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  line-height: 1.4;
}

.angle-chip-active .angle-chip-desc {
  color: rgba(0, 245, 160, 0.7);
}
