<!-- pages/analyze/analyze.wxml -->
<view class="page-container">

  <!-- Injury Prevention Banner (P1 marketing alignment) -->
  <view class="injury-prevention-banner">
    <text class="injury-banner-text">🛡️ {{i.injuryPreventionBanner || '别让错误跑姿毁了你的跑步热情'}}</text>
  </view>

  <!-- Header card -->
  <view class="card">
    <view class="header-row">
      <view class="icon-bubble">🏃</view>
      <view class="header-text">
        <text class="title">{{i.analyzeTitle}}</text>
        <text class="subtitle">{{i.analyzeSubtitle}}</text>
      </view>
    </view>
  </view>

  <!-- Recording guide -->
  <view class="card-dark">
    <text class="section-title">{{i.videoGuide}}</text>
    <text class="body-text">{{i.videoGuideBody}}</text>
    <view class="guide-tips">
      <view class="tip-row" wx:for="{{tips}}" wx:key="index">
        <text class="tip-icon">{{item.icon}}</text>
        <text class="tip-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <!-- RF-308: Angle selection -->
  <view class="card angle-card">
    <text class="section-title">{{i.cameraAngle}}</text>
    <view class="angle-chips">
      <view
        class="angle-chip {{cameraAngle === 'side' ? 'angle-chip-active' : ''}}"
        bindtap="selectAngle"
        data-angle="side"
      >
        <view class="angle-chip-icon">📐🧑‍➡️</view>
        <text class="angle-chip-label">{{i.angleSide}}</text>
        <text class="angle-chip-desc">{{i.angleSideDesc}}</text>
      </view>
      <view
        class="angle-chip {{cameraAngle === 'rear' ? 'angle-chip-active' : ''}}"
        bindtap="selectAngle"
        data-angle="rear"
      >
        <view class="angle-chip-icon">👤</view>
        <text class="angle-chip-label">{{i.angleRear}}</text>
        <text class="angle-chip-desc">{{i.angleRearDesc}}</text>
      </view>
      <view
        class="angle-chip {{cameraAngle === 'front' ? 'angle-chip-active' : ''}}"
        bindtap="selectAngle"
        data-angle="front"
      >
        <view class="angle-chip-icon">🧑</view>
        <text class="angle-chip-label">{{i.angleFront}}</text>
        <text class="angle-chip-desc">{{i.angleFrontDesc}}</text>
      </view>
    </view>
  </view>

  <!-- Video picker area -->
  <view class="card">
    <view class="video-area" bindtap="pickVideo">
      <block wx:if="{{!videoPath}}">
        <text class="video-placeholder-icon">🎬</text>
        <text class="video-placeholder-text">{{i.pickVideo}}</text>
        <text class="caption" style="margin-top: 8rpx; text-align: center;">点击选择或录制跑步视频</text>
      </block>
      <block wx:else>
        <video
          class="video-preview"
          src="{{videoPath}}"
          controls="{{false}}"
          autoplay="{{false}}"
          loop="{{false}}"
          muted="{{true}}"
          show-play-btn="{{false}}"
        />
        <view class="video-overlay">
          <text class="video-overlay-text">{{videoName}}</text>
          <text class="video-overlay-sub">{{videoDurationText}} · {{videoSizeText}}</text>
        </view>
      </block>
    </view>

    <!-- Action row -->
    <view class="action-row" style="margin-top: 20rpx;">
      <button class="btn-secondary pick-btn" bindtap="pickVideo">{{i.pickVideo}}</button>
      <view style="width: 16rpx;"></view>
      <button
        class="btn-primary analyze-btn"
        bindtap="analyze"
        disabled="{{!videoPath || analyzing}}"
      >
        <block wx:if="{{analyzing}}">
          <view class="loading-row">
            <view class="spinner"></view>
            <text style="margin-left: 12rpx;">{{uploadProgress > 0 ? i.uploadProgress + ' ' + uploadProgress + '%' : i.analyzing}}</text>
          </view>
        </block>
        <block wx:else>{{i.analyzeBtn}}</block>
      </button>
    </view>
  </view>

  <!-- Upload progress bar -->
  <view wx:if="{{analyzing && uploadProgress > 0}}" class="progress-card">
    <view class="progress-label-row">
      <text class="label">{{compressing ? '压缩中' : i.uploadProgress}}</text>
      <text class="text-mint">{{uploadProgress}}%</text>
    </view>
    <view class="progress-track">
      <view class="progress-fill" style="width: {{uploadProgress}}%;"></view>
    </view>
    <text wx:if="{{compressResult && compressResult.compressed}}" class="caption" style="margin-top: 12rpx; display: block;">
      视频已压缩：{{compressResult.originalSizeMB}}MB → {{compressResult.compressedSizeMB}}MB
    </text>
  </view>

</view>
