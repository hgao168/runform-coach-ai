/* pages/compare/compare.wxss */

.header-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 24rpx;
}

.icon-bubble {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(0,245,160,0.18), rgba(0,212,255,0.18));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.header-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.loading-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 5rpx solid rgba(255,255,255,0.12);
  border-top-color: #00f5a0;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.error-card {
  background: rgba(255,71,87,0.1);
  border: 1rpx solid rgba(255,71,87,0.25);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.athlete-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  gap: 20rpx;
}

.athlete-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, rgba(0,245,160,0.3), rgba(0,212,255,0.3));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.athlete-avatar-initial {
  font-size: 40rpx;
  font-weight: 800;
  color: #00f5a0;
}

.athlete-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.athlete-name {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.92);
}

.athlete-meta {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

.athlete-achievement {
  font-size: 24rpx;
  color: #ff9f30;
  margin-top: 4rpx;
}

.chevron {
  font-size: 40rpx;
  color: rgba(255,255,255,0.3);
}

.info-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  background: rgba(0,212,255,0.06);
  border: 1rpx solid rgba(0,212,255,0.18);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

.info-icon { font-size: 36rpx; flex-shrink: 0; }

.info-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.6;
}

.info-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-inline-mint {
  background: rgba(0,245,160,0.15);
  border: 1rpx solid rgba(0,245,160,0.35);
  color: #00f5a0;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
  align-self: flex-start;
}

.back-btn {
  background: rgba(255,255,255,0.08);
  border: none;
  color: rgba(255,255,255,0.72);
  font-size: 28rpx;
  border-radius: 14rpx;
  padding: 12rpx 28rpx;
  margin-bottom: 24rpx;
  align-self: flex-start;
  display: inline-block;
}

.detail-hero-card {
  background: linear-gradient(135deg, rgba(0,245,160,0.1), rgba(0,212,255,0.06));
  border: 1rpx solid rgba(0,245,160,0.2);
  border-radius: 28rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.detail-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background: linear-gradient(135deg, #00f5a0, #00d4ff);
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-avatar-initial {
  font-size: 64rpx;
  font-weight: 800;
  color: #0a0a0f;
}

.detail-name {
  font-size: 40rpx;
  font-weight: 800;
  color: rgba(255,255,255,0.95);
}

.detail-meta {
  font-size: 26rpx;
  color: rgba(255,255,255,0.56);
}

.stats-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
}

.stat-item {
  background: rgba(255,255,255,0.06);
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 160rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 800;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  text-align: center;
}

.achievement-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-top: 14rpx;
}

.achievement-dot {
  font-size: 30rpx;
  color: #ff9f30;
  flex-shrink: 0;
}

.achievement-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.75);
  line-height: 1.5;
}

/* ── Comparison UI ── */

.no-analysis-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx 20rpx;
}

.comparing-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

/* Comparison table */
.comparison-table {
  margin-top: 12rpx;
}

.comp-header-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 12rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  gap: 8rpx;
}

.comp-header-label {
  flex: 0 0 120rpx;
}

.comp-header-you,
.comp-header-elite,
.comp-header-gap {
  flex: 1;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.42);
  text-align: center;
}

.comp-data-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 12rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
  gap: 8rpx;
}

.comp-metric-label {
  flex: 0 0 120rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.78);
}

.comp-value-you {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #00d4ff;
  text-align: center;
}

.comp-value-elite {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #ff9f30;
  text-align: center;
}

.comp-value-gap {
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.comp-unit-hint {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.3);
  text-align: right;
  margin-top: 8rpx;
  padding-right: 12rpx;
}

/* ═══════════════════════════════════════ */
/* Rich Compare Result View               */
/* ═══════════════════════════════════════ */

.result-view {
  margin-top: 8rpx;
}

/* ── 1. Similarity Ring Chart ── */

.similarity-section {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 8rpx;
}

.ring-wrapper {
  position: relative;
  width: 220rpx;
  height: 220rpx;
}

.ring-canvas {
  width: 220rpx;
  height: 220rpx;
}

.ring-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.ring-score-text {
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
}

.ring-label-text {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.45);
}

/* ── 2. AI Coach Narrative ── */

.coach-card {
  background: linear-gradient(135deg, rgba(0,212,255,0.08), rgba(0,245,160,0.04));
  border: 1rpx solid rgba(0,212,255,0.2);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  position: relative;
}

.coach-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.coach-quote-icon {
  font-size: 48rpx;
  color: #00d4ff;
  line-height: 1;
  font-weight: 700;
}

.coach-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  flex: 1;
}

.ai-badge {
  background: linear-gradient(135deg, #00f5a0, #00d4ff);
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
  flex-shrink: 0;
}

.ai-badge-text {
  font-size: 20rpx;
  font-weight: 800;
  color: #0a0a0f;
}

.coach-narrative-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.72);
  line-height: 1.7;
}

/* ── 3. Top Gaps List ── */

.gaps-section {
  margin-top: 24rpx;
}

.gaps-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 16rpx;
  display: block;
}

.gap-card {
  background: rgba(255,71,87,0.06);
  border: 1rpx solid rgba(255,71,87,0.15);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.gap-header-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.gap-metric-tag {
  background: rgba(255,71,87,0.15);
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
}

.gap-metric-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ff4757;
}

.gap-value-text {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  text-align: right;
}

.gap-suggestion-text {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.62);
  line-height: 1.6;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}

/* ── 4. Metric Comparison Grid ── */

.metric-grid-section {
  margin-top: 24rpx;
}

.metric-grid-row {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.metric-label-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.metric-label-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.metric-label-unit {
  font-size: 20rpx;
  color: rgba(255,255,255,0.38);
}

.metric-direction {
  font-size: 18rpx;
  font-weight: 600;
  margin-left: auto;
}

.metric-values-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.metric-user-col,
.metric-elite-col,
.metric-gap-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.metric-col-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
  font-weight: 600;
}

.metric-col-value {
  font-size: 30rpx;
  font-weight: 800;
}

/* Progress bars */
.metric-progress-section {
  margin-top: 4rpx;
}

.metric-progress-track {
  position: relative;
  height: 12rpx;
  border-radius: 6rpx;
  overflow: visible;
}

.metric-progress-user {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.6s ease;
}

.metric-progress-elite-marker {
  position: absolute;
  top: -4rpx;
  width: 4rpx;
  height: 20rpx;
  background: #ff9f30;
  border-radius: 2rpx;
  transform: translateX(-50%);
}

.metric-progress-labels {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.metric-progress-status {
  font-size: 22rpx;
  font-weight: 700;
}

.metric-progress-target-hint {
  font-size: 20rpx;
  color: rgba(255,255,255,0.36);
}
