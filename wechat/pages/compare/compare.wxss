/* pages/compare/compare.wxss */

.header-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 24rpx;
}

.icon-bubble {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(0,245,160,0.18), rgba(0,212,255,0.18));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.header-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.loading-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 5rpx solid rgba(255,255,255,0.12);
  border-top-color: #00f5a0;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.error-card {
  background: rgba(255,71,87,0.1);
  border: 1rpx solid rgba(255,71,87,0.25);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.athlete-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  gap: 20rpx;
}

.athlete-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, rgba(0,245,160,0.3), rgba(0,212,255,0.3));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.athlete-avatar-initial {
  font-size: 40rpx;
  font-weight: 800;
  color: #00f5a0;
}

.athlete-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.athlete-name {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.92);
}

.athlete-meta {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

.athlete-achievement {
  font-size: 24rpx;
  color: #ff9f30;
  margin-top: 4rpx;
}

.chevron {
  font-size: 40rpx;
  color: rgba(255,255,255,0.3);
}

.info-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  background: rgba(0,212,255,0.06);
  border: 1rpx solid rgba(0,212,255,0.18);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

.info-icon { font-size: 36rpx; flex-shrink: 0; }

.info-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.6;
}

.info-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-inline-mint {
  background: rgba(0,245,160,0.15);
  border: 1rpx solid rgba(0,245,160,0.35);
  color: #00f5a0;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
  align-self: flex-start;
}

.back-btn {
  background: rgba(255,255,255,0.08);
  border: none;
  color: rgba(255,255,255,0.72);
  font-size: 28rpx;
  border-radius: 14rpx;
  padding: 12rpx 28rpx;
  margin-bottom: 24rpx;
  align-self: flex-start;
  display: inline-block;
}

.detail-hero-card {
  background: linear-gradient(135deg, rgba(0,245,160,0.1), rgba(0,212,255,0.06));
  border: 1rpx solid rgba(0,245,160,0.2);
  border-radius: 28rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.detail-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background: linear-gradient(135deg, #00f5a0, #00d4ff);
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-avatar-initial {
  font-size: 64rpx;
  font-weight: 800;
  color: #0a0a0f;
}

.detail-name {
  font-size: 40rpx;
  font-weight: 800;
  color: rgba(255,255,255,0.95);
}

.detail-meta {
  font-size: 26rpx;
  color: rgba(255,255,255,0.56);
}

.stats-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
}

.stat-item {
  background: rgba(255,255,255,0.06);
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 160rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 800;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  text-align: center;
}

.achievement-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-top: 14rpx;
}

.achievement-dot {
  font-size: 30rpx;
  color: #ff9f30;
  flex-shrink: 0;
}

.achievement-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.75);
  line-height: 1.5;
}

/* ── Comparison UI ── */

.no-analysis-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx 20rpx;
}

.comparing-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

/* Comparison table */
.comparison-table {
  margin-top: 12rpx;
}

.comp-header-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 12rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  gap: 8rpx;
}

.comp-header-label {
  flex: 0 0 120rpx;
}

.comp-header-you,
.comp-header-elite,
.comp-header-gap {
  flex: 1;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.42);
  text-align: center;
}

.comp-data-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 12rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
  gap: 8rpx;
}

.comp-metric-label {
  flex: 0 0 120rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.78);
}

.comp-value-you {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #00d4ff;
  text-align: center;
}

.comp-value-elite {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #ff9f30;
  text-align: center;
}

.comp-value-gap {
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.comp-unit-hint {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.3);
  text-align: right;
  margin-top: 8rpx;
  padding-right: 12rpx;
}
