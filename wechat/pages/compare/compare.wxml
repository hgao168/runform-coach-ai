<!-- pages/compare/compare.wxml -->
<view class="page-container">

  <!-- Header -->
  <view class="card">
    <view class="header-row">
      <view class="icon-bubble">🏅</view>
      <view class="header-text">
        <text class="title">{{i.compareTitle}}</text>
        <text class="subtitle">{{i.compareSubtitle}}</text>
      </view>
    </view>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-center">
    <view class="loading-spinner"></view>
    <text class="caption" style="margin-top: 16rpx;">{{i.loading}}</text>
  </view>

  <!-- Error -->
  <view wx:elif="{{loadError}}" class="error-card">
    <text class="body-text">{{loadError}}</text>
    <button class="btn-secondary" style="margin-top: 20rpx; height: 80rpx;" bindtap="loadAthletes">{{i.retry}}</button>
  </view>

  <!-- Athletes list -->
  <view wx:elif="{{!selectedAthlete}}">
    <view
      wx:for="{{athletes}}"
      wx:key="id"
      class="athlete-card"
      bindtap="selectAthlete"
      data-id="{{item.id}}"
    >
      <view class="athlete-avatar">
        <text class="athlete-avatar-initial">{{item.initial}}</text>
      </view>
      <view class="athlete-info">
        <text class="athlete-name">{{item.name}}</text>
        <text class="athlete-meta">{{item.event}} · {{item.nationality}}</text>
        <text class="athlete-achievement" wx:if="{{item.bestAchievement}}">🏆 {{item.bestAchievement}}</text>
      </view>
      <text class="chevron">›</text>
    </view>

    <!-- No analysis prompt at list level -->
    <view wx:if="{{!hasAnalysis}}" class="info-card" style="border-color: rgba(255,159,48,0.3); background: rgba(255,159,48,0.06);">
      <text class="info-icon">⚠️</text>
      <view class="info-text-wrap">
        <text class="info-text">{{i.noAnalysisForCompare}}</text>
        <button class="btn-inline-mint" bindtap="goAnalyze">{{i.goAnalyzeNow}} →</button>
      </view>
    </view>

    <!-- iOS compare note -->
    <view class="info-card">
      <text class="info-icon">💡</text>
      <text class="info-text">{{i.compareNote}}</text>
    </view>
  </view>

  <!-- Athlete detail -->
  <view wx:elif="{{selectedAthlete}}">

    <button class="back-btn" bindtap="clearAthlete">‹ {{i.back}}</button>

    <view class="detail-hero-card">
      <view class="detail-avatar">
        <text class="detail-avatar-initial">{{selectedAthlete.initial}}</text>
      </view>
      <text class="detail-name">{{selectedAthlete.name}}</text>
      <text class="detail-meta">{{selectedAthlete.event}} · {{selectedAthlete.nationality}}</text>
    </view>

    <!-- Bio -->
    <view class="card" wx:if="{{selectedAthlete.bio}}">
      <text class="section-title">{{i.athleteBio}}</text>
      <text class="body-text" style="margin-top: 12rpx;">{{selectedAthlete.bio}}</text>
    </view>

    <!-- Comparison section -->
    <view class="card">
      <text class="section-title">⚡ {{i.compareResult}}</text>

      <!-- No analysis state -->
      <view wx:if="{{!hasAnalysis}}" class="no-analysis-block">
        <text style="font-size: 56rpx; margin-bottom: 12rpx;">📊</text>
        <text class="body-text" style="text-align: center;">{{i.noAnalysisForCompare}}</text>
        <button class="btn-mint-outline" style="margin-top: 24rpx;" bindtap="goAnalyze">{{i.goAnalyzeNow}}</button>
      </view>

      <!-- Comparing loading -->
      <view wx:elif="{{comparing}}" class="comparing-block">
        <view class="loading-spinner" style="margin: 20rpx auto;"></view>
        <text class="caption" style="margin-top: 16rpx;">{{i.comparing}}</text>
      </view>

      <!-- Comparison table (simple fallback when no rich result) -->
      <view wx:elif="{{comparisonRows.length > 0 && !showResultView}}" class="comparison-table">
        <!-- Header row -->
        <view class="comp-header-row">
          <text class="comp-header-label"></text>
          <text class="comp-header-you">🙋 {{i.yourMetrics}}</text>
          <text class="comp-header-elite">🏅 {{i.eliteMetrics}}</text>
          <text class="comp-header-gap">{{i.gap}}</text>
        </view>

        <!-- Data rows -->
        <view wx:for="{{comparisonRows}}" wx:key="label" class="comp-data-row">
          <text class="comp-metric-label">{{item.label}}</text>
          <text class="comp-value-you">{{item.userDisplay}}</text>
          <text class="comp-value-elite">{{item.eliteDisplay}}</text>
          <text class="comp-value-gap" style="color: {{item.diffColor || 'rgba(255,255,255,0.45)'}};">{{item.diffDisplay}}</text>
        </view>

        <text class="comp-unit-hint" wx:if="{{comparisonRows.length > 0}}">
          {{comparisonRows[0].unit}}
        </text>
      </view>

      <!-- ═══════════════════════════════════════ -->
      <!-- Rich Compare Result View (iOS CompareResultView) -->
      <!-- ═══════════════════════════════════════ -->
      <view wx:elif="{{showResultView}}" class="result-view">

        <!-- ── 1. Similarity Ring Chart ── -->
        <view class="similarity-section">
          <view class="ring-wrapper">
            <canvas type="2d" id="similarityRingCanvas" class="ring-canvas"></canvas>
            <view class="ring-center">
              <text class="ring-score-text">{{similarityScore}}%</text>
              <text class="ring-label-text">{{i.similarityLabel}}</text>
            </view>
          </view>
        </view>

        <!-- ── 2. AI Coach Narrative ── -->
        <view wx:if="{{coachingNarrative}}" class="coach-card">
          <view class="coach-card-header">
            <text class="coach-quote-icon">{{i.coachQuote}}</text>
            <text class="coach-title">{{i.aiCoachCommentTitle}}</text>
            <view class="ai-badge">
              <text class="ai-badge-text">{{i.aiPoweredBadge}}</text>
            </view>
          </view>
          <text class="coach-narrative-text">{{coachingNarrative}}</text>
        </view>

        <!-- ── 3. Top Gaps List ── -->
        <view wx:if="{{topGaps.length > 0}}" class="gaps-section">
          <text class="gaps-title">⚠️ {{i.topGapsTitle}}</text>
          <view wx:for="{{topGaps}}" wx:key="id" class="gap-card">
            <view class="gap-header-row">
              <view class="gap-metric-tag">
                <text class="gap-metric-text">{{item.metric}}</text>
              </view>
              <text class="gap-value-text">{{item.gap}}</text>
            </view>
            <text wx:if="{{item.suggestion}}" class="gap-suggestion-text">💡 {{item.suggestion}}</text>
          </view>
        </view>

        <!-- ── 4. Metric Comparison Grid with Progress Bars ── -->
        <view wx:if="{{metricGrid.length > 0}}" class="metric-grid-section">
          <text class="gaps-title">📊 {{i.compareResult}}</text>
          <view wx:for="{{metricGrid}}" wx:key="label" class="metric-grid-row">
            <!-- Label row -->
            <view class="metric-label-row">
              <text class="metric-label-name">{{item.label}}</text>
              <text wx:if="{{item.unit}}" class="metric-label-unit">{{item.unit}}</text>
              <text class="metric-direction" style="color: {{item.higherIsBetter ? '#00d4ff' : '#ff9f30'}};">
                {{item.higherIsBetter ? i.higherBetter : i.lowerBetter}}
              </text>
            </view>

            <!-- Values row -->
            <view class="metric-values-row">
              <view class="metric-user-col">
                <text class="metric-col-label">{{i.yourValueShort}}</text>
                <text class="metric-col-value" style="color: {{item.isGood ? '#00f5a0' : '#ff4757'}};">{{item.userDisplay}}</text>
              </view>
              <view class="metric-elite-col">
                <text class="metric-col-label">{{i.eliteValueShort}}</text>
                <text class="metric-col-value text-orange">{{item.eliteDisplay}}</text>
              </view>
              <view class="metric-gap-col">
                <text class="metric-col-label">{{i.gapValue}}</text>
                <text class="metric-col-value" style="color: {{item.isGood ? '#00f5a0' : '#ff4757'}};">{{item.diffDisplay}}</text>
              </view>
            </view>

            <!-- Progress bars -->
            <view class="metric-progress-section">
              <view class="metric-progress-track" style="background: {{item.trackColor}};">
                <!-- User bar -->
                <view class="metric-progress-user" style="width: {{item.userPct}}%; background: {{item.progressColor}};"></view>
                <!-- Elite marker line -->
                <view class="metric-progress-elite-marker" style="left: {{item.elitePct}}%;"></view>
              </view>
              <view class="metric-progress-labels">
                <text class="metric-progress-status" style="color: {{item.isGood ? '#00f5a0' : '#ff4757'}};">
                  {{item.isGood ? i.closeToElite : i.needsWork}}
                </text>
                <text class="metric-progress-target-hint">{{i.progressTarget}}: {{item.eliteDisplay}}</text>
              </view>
            </view>
          </view>
        </view>

      </view>

      <!-- Comparison error fallback -->
      <view wx:elif="{{compareError}}" class="error-card" style="margin-top: 8rpx;">
        <text class="body-text">{{compareError}}</text>
      </view>

      <!-- No comparison data -->
      <view wx:else class="no-analysis-block">
        <text class="body-text" style="text-align: center;">{{i.noCompareData}}</text>
      </view>
    </view>

    <!-- Elite stats (original) -->
    <view class="card" wx:if="{{selectedAthlete.stats.length > 0}}">
      <text class="section-title">📊 {{i.trainingParams}}</text>
      <view class="stats-grid">
        <view wx:for="{{selectedAthlete.stats}}" wx:key="label" class="stat-item">
          <text class="stat-value text-mint">{{item.value}}</text>
          <text class="stat-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- Achievements -->
    <view class="card" wx:if="{{selectedAthlete.achievements.length > 0}}">
      <text class="section-title">🏆 {{i.achievement}}</text>
      <view wx:for="{{selectedAthlete.achievements}}" wx:key="index" class="achievement-row">
        <text class="achievement-dot">·</text>
        <text class="achievement-text">{{item}}</text>
      </view>
    </view>

    <!-- RF-304: Share button -->
    <button class="btn-mint-outline" style="width: 100%; height: 96rpx; font-size: 30rpx; border-radius: 28rpx; margin-top: 8rpx;" open-type="share">
      📤 {{i.shareResult}}
    </button>

    <!-- RF-913: Save share image to album -->
    <button class="btn-secondary" style="width: 100%; height: 96rpx; font-size: 30rpx; border-radius: 28rpx; margin-top: 20rpx;" bindtap="saveShareToAlbum">
      🖼️ {{isZh ? '保存到相册' : 'Save to Album'}}
    </button>

  </view>

  <!-- RF-913: Hidden canvas for share image generation -->
  <canvas
    type="2d"
    id="shareCanvas"
    style="position: fixed; left: -9999rpx; top: -9999rpx; width: 600rpx; height: 928rpx;"
  />

</view>
