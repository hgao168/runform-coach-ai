/* pages/club-leaderboard/club-leaderboard.wxss */
/* RF-603: Club leaderboard styles */

.club-page {
  min-height: 100vh;
  background: #0a0a0f;
  padding: 24rpx 32rpx;
}

/* ── Coming Soon Banner ── */
.coming-soon-banner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(255,159,48,0.1) 0%, rgba(255,107,157,0.06) 100%);
  border: 1rpx solid rgba(255,159,48,0.2);
  border-radius: 16rpx;
  margin-bottom: 28rpx;
}

.cs-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.cs-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.cs-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ff9f30;
}

.cs-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  line-height: 1.5;
}

/* ── Club Header ── */
.club-header {
  text-align: center;
  padding: 20rpx 0 32rpx;
}

.club-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.club-code-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(0,245,160,0.1);
  border: 1rpx solid rgba(0,245,160,0.2);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #00f5a0;
}

/* ── Podium Top 3 ── */
.podium {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 0 40rpx;
  min-height: 340rpx;
}

.podium-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  max-width: 200rpx;
}

.podium-1st {
  order: 2;
}

.podium-2nd {
  order: 1;
}

.podium-3rd {
  order: 3;
}

.podium-medal {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.podium-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.5);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255,255,255,0.15);
}

.podium-avatar.gold {
  width: 96rpx;
  height: 96rpx;
  border-color: rgba(255,215,0,0.5);
  background: rgba(255,215,0,0.1);
  color: #ffd700;
  box-shadow: 0 0 24rpx rgba(255,215,0,0.2);
}

.podium-name {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.podium-score {
  font-size: 22rpx;
  color: #00f5a0;
  font-weight: 600;
}

.podium-bar {
  width: 100%;
  border-radius: 8rpx 8rpx 0 0;
}

.podium-bar.first {
  height: 90rpx;
  background: linear-gradient(180deg, #ffd700, rgba(255,215,0,0.3));
}

.podium-bar.second {
  height: 64rpx;
  background: linear-gradient(180deg, #c0c0c0, rgba(192,192,192,0.3));
}

.podium-bar.third {
  height: 50rpx;
  background: linear-gradient(180deg, #cd7f32, rgba(205,127,50,0.3));
}

/* ── Rank list header ── */
.rank-list-header {
  padding: 16rpx 0 20rpx;
}

.rlh-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

/* ── Rank list ── */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 14rpx;
  border: 1rpx solid transparent;
}

.rank-item.is-me {
  background: rgba(0,245,160,0.08);
  border-color: rgba(0,245,160,0.15);
}

.ri-rank {
  width: 56rpx;
  text-align: center;
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  font-weight: 600;
  flex-shrink: 0;
}

.ri-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0,245,160,0.12);
  color: #00f5a0;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ri-avatar.gold {
  background: rgba(255,215,0,0.12);
  color: #ffd700;
}

.ri-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.ri-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ri-stats {
  display: flex;
  gap: 16rpx;
}

.ri-stat {
  font-size: 20rpx;
  color: rgba(255,255,255,0.35);
}

/* ── Rank change ── */
.ri-change {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  flex-shrink: 0;
  min-width: 72rpx;
}

.ri-change-val {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.35);
}

.ri-change-val.up {
  color: #00f5a0;
}

.ri-change-val.down {
  color: #ff4757;
}

.ri-change-label {
  font-size: 18rpx;
  color: rgba(255,255,255,0.2);
}

/* ── Me badge ── */
.ri-me-badge {
  background: rgba(0,245,160,0.15);
  border: 1rpx solid rgba(0,245,160,0.3);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: #00f5a0;
  font-weight: 600;
  flex-shrink: 0;
}

/* ── Empty states ── */
.empty-club {
  text-align: center;
  padding: 160rpx 32rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 8rpx;
  font-weight: 600;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.3);
  line-height: 1.5;
}

.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
}

.loading-state {
  text-align: center;
  padding: 200rpx 0;
  color: rgba(255,255,255,0.3);
  font-size: 28rpx;
}
