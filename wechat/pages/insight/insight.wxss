/* pages/insight/insight.wxss */
/* RF-1010: Weekly Training Insight Report */

/* ── Page header ── */
.insight-header {
  padding: 16rpx 0 12rpx 0;
}

/* ── Spinner ── */
.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.12);
  border-top-color: #00f5a0;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── Comparison Grid ── */
.compare-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 12rpx;
}

.compare-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
}

.compare-icon {
  font-size: 36rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  flex-shrink: 0;
}

.compare-body {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.compare-label {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
}

.compare-value-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.compare-value {
  font-size: 30rpx;
  font-weight: 700;
}

.compare-arrow {
  font-size: 24rpx;
  font-weight: 700;
}

.text-red {
  color: #ff4757;
}

/* ── Trend Chart ── */
.trend-canvas-wrap {
  position: relative;
  width: 100%;
  height: 380rpx;
  margin-top: 8rpx;
}

.trend-canvas {
  width: 100%;
  height: 100%;
}

.trend-tooltip {
  position: absolute;
  pointer-events: none;
  z-index: 10;
  transform: translate(-50%, -100%);
}

.trend-tooltip-inner {
  background: rgba(10, 10, 15, 0.94);
  border: 1rpx solid;
  border-radius: 12rpx;
  padding: 10rpx 20rpx;
  white-space: nowrap;
}

.trend-tooltip-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.trend-legend-hint {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 32rpx;
  margin-top: 10rpx;
}

.trend-legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.trend-legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
}

.trend-legend-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
}

/* ── AI Advice Card ── */
.ai-card {
  border-color: rgba(0, 245, 160, 0.2) !important;
  background: rgba(0, 245, 160, 0.04) !important;
}

.ai-advice-body {
  background: rgba(0, 245, 160, 0.06);
  border: 1rpx solid rgba(0, 245, 160, 0.12);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 8rpx;
}

.ai-advice-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.8;
}

/* ── Badges Grid ── */
.badges-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.badge-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 22rpx;
  background: rgba(255, 159, 48, 0.06);
  border: 1rpx solid rgba(255, 159, 48, 0.18);
  border-radius: 20rpx;
  flex: 1;
  min-width: 280rpx;
}

.badge-icon-wrap {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 159, 48, 0.12);
  border-radius: 16rpx;
  flex-shrink: 0;
}

.badge-icon {
  font-size: 32rpx;
}

.badge-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.badge-name {
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.88);
}

.badge-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.48);
  line-height: 1.4;
}
