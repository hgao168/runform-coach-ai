<!-- pages/history/history.wxml -->
<view class="page-container">

  <!-- Header -->
  <view class="history-header">
    <text class="title">{{i.historyTitle}}</text>
    <text wx:if="{{items.length > 0}}" class="clear-btn" bindtap="confirmClear">{{i.deleteHistory}}</text>
  </view>

  <!-- Trend chart section (collapsible) -->
  <view wx:if="{{items.length >= 2}}" class="trend-section">
    <view class="trend-header" bindtap="toggleTrend">
      <view class="trend-header-left">
        <text class="trend-icon">📈</text>
        <text class="trend-title">{{i.trendTitle}}</text>
      </view>
      <text class="trend-toggle">{{trendExpanded ? i.trendToggleHide : i.trendToggle}}</text>
    </view>

    <view wx:if="{{trendExpanded}}" class="trend-body">
      <view wx:if="{{trendHasData}}" class="trend-canvas-wrap">
        <canvas
          type="2d"
          id="trendCanvas"
          class="trend-canvas"
          bindtouchstart="onChartTap"
        ></canvas>
        <!-- Tooltip overlay -->
        <view
          wx:if="{{trendTooltip}}"
          class="trend-tooltip"
          style="left: {{trendTooltip.x}}px; top: {{trendTooltip.y}}px;"
        >
          <view class="trend-tooltip-inner" style="border-color: {{trendTooltip.color}};">
            <text class="trend-tooltip-text">{{trendTooltip.text}}</text>
          </view>
        </view>
        <!-- Legend hint -->
        <view class="trend-legend-hint">
          <view wx:for="{{trendDatasets}}" wx:key="label" class="trend-legend-item">
            <view class="trend-legend-dot" style="background: {{item.color}};"></view>
            <text class="trend-legend-label">{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- Not enough data for chart -->
      <view wx:else class="trend-empty">
        <text class="trend-empty-icon">📉</text>
        <text class="trend-empty-text">{{i.trendNoData}}</text>
      </view>

      <text class="trend-tap-hint">{{i.trendTapHint}}</text>
    </view>
  </view>

  <!-- Empty state -->
  <view wx:if="{{items.length === 0}}" class="empty-state">
    <text style="font-size: 72rpx; margin-bottom: 20rpx;">🏃‍♂️</text>
    <text class="empty-title">{{i.historyEmpty}}</text>
    <text class="empty-sub">{{i.historyEmptySub}}</text>
    <button class="btn-primary" style="margin-top: 40rpx; padding: 0 48rpx; height: 88rpx; font-size: 28rpx;" bindtap="goAnalyze">{{i.startFirstAnalysis}}</button>
  </view>

  <!-- History list -->
  <view wx:else>
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="history-card"
      bindtap="openItem"
      data-index="{{index}}"
    >
      <view class="history-card-left">
        <view class="score-circle" style="border-color: {{item.scoreColor}};">
          <text class="score-text" style="color: {{item.scoreColor}};">{{item.scoreDisplay}}</text>
        </view>
      </view>
      <view class="history-card-body">
        <text class="history-date">{{item.dateDisplay}}</text>
        <text class="history-summary">{{item.summary}}</text>
      </view>
      <text class="chevron">›</text>
    </view>
  </view>

</view>
