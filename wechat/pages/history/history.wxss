/* pages/history/history.wxss */

.history-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0 28rpx 0;
}

.clear-btn {
  font-size: 26rpx;
  color: #ff4757;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.72);
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
  text-align: center;
  line-height: 1.6;
  white-space: pre-line;
}

.history-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 16rpx;
  gap: 20rpx;
}

.history-card-left {
  flex-shrink: 0;
}

.score-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  border: 3rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-text {
  font-size: 28rpx;
  font-weight: 800;
}

.history-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-date {
  font-size: 24rpx;
  color: rgba(255,255,255,0.48);
}

.history-summary {
  font-size: 26rpx;
  color: rgba(255,255,255,0.82);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.chevron {
  font-size: 40rpx;
  color: rgba(255,255,255,0.3);
  flex-shrink: 0;
}
