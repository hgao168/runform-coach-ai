/* pages/history/history.wxss */

.history-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0 28rpx 0;
}

.clear-btn {
  font-size: 26rpx;
  color: #ff4757;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.72);
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
  text-align: center;
  line-height: 1.6;
  white-space: pre-line;
}

.history-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 16rpx;
  gap: 20rpx;
}

.history-card-left {
  flex-shrink: 0;
}

.score-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  border: 3rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-text {
  font-size: 28rpx;
  font-weight: 800;
}

.history-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-date {
  font-size: 24rpx;
  color: rgba(255,255,255,0.48);
}

.history-summary {
  font-size: 26rpx;
  color: rgba(255,255,255,0.82);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.chevron {
  font-size: 40rpx;
  color: rgba(255,255,255,0.3);
  flex-shrink: 0;
}

/* ── Trend chart section ── */

.trend-section {
  margin-bottom: 24rpx;
}

.trend-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
}

.trend-header-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.trend-icon {
  font-size: 32rpx;
}

.trend-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
}

.trend-toggle {
  font-size: 24rpx;
  color: #00f5a0;
  font-weight: 500;
}

.trend-body {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 0 0 24rpx 24rpx;
  border-top: none;
  padding: 16rpx 8rpx 24rpx;
  overflow: hidden;
}

.trend-canvas-wrap {
  position: relative;
  width: 100%;
  height: 440rpx;
}

.trend-canvas {
  width: 100%;
  height: 100%;
}

/* Tooltip */
.trend-tooltip {
  position: absolute;
  pointer-events: none;
  z-index: 10;
  transform: translate(-50%, -100%);
}

.trend-tooltip-inner {
  background: rgba(10,10,15,0.94);
  border: 1rpx solid;
  border-radius: 12rpx;
  padding: 10rpx 20rpx;
  white-space: nowrap;
}

.trend-tooltip-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
}

/* Legend below canvas */
.trend-legend-hint {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 32rpx;
  margin-top: 12rpx;
}

.trend-legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.trend-legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
}

.trend-legend-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
}

/* Empty trend state */
.trend-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  gap: 12rpx;
}

.trend-empty-icon {
  font-size: 48rpx;
}

.trend-empty-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.42);
}

.trend-tap-hint {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: rgba(255,255,255,0.28);
  margin-top: 12rpx;
}

/* ── RF-605: Milestone Banner ── */

.milestone-banner {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, rgba(255,159,48,0.15), rgba(0,245,160,0.08));
  border: 1rpx solid rgba(255,159,48,0.3);
  border-radius: 24rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 24rpx;
}

.milestone-banner-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.milestone-banner-icon {
  font-size: 44rpx;
}

.milestone-banner-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.milestone-banner-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ff9f30;
}

.milestone-banner-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  line-height: 1.4;
}

.milestone-banner-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.milestone-banner-arrow {
  font-size: 26rpx;
  color: #ff9f30;
  font-weight: 600;
}

.milestone-dismiss-btn {
  font-size: 28rpx;
  color: rgba(255,255,255,0.35);
  padding: 4rpx 12rpx;
}

/* ── RF-605: Milestone Celebration Modal ── */

.milestone-modal-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.milestone-modal {
  width: 100%;
  max-height: 90vh;
  background: #14141e;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 32rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.milestone-modal-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.milestone-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ff9f30;
}

.milestone-modal-close {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 8rpx 16rpx;
}

.milestone-canvas-wrap {
  width: 100%;
  aspect-ratio: 375 / 580;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.milestone-canvas {
  width: 100%;
  height: 100%;
}

.milestone-summary {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.milestone-stat {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.06);
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.milestone-stat-value {
  font-weight: 700;
  color: #00f5a0;
}

.milestone-actions {
  display: flex;
  flex-direction: row;
  gap: 0;
}
