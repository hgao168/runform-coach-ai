<!-- pages/challenge/challenge.wxml -->
<view class="challenge-page">
  <!-- Header -->
  <view class="challenge-header">
    <text class="challenge-title">{{i.challengeTitle || '14天跑姿改善挑战'}}</text>
    <text class="challenge-sub">{{i.challengeSub || '每天改善一点，14天后遇见更好的跑姿'}}</text>
  </view>

  <!-- Not joined state -->
  <block wx:if="{{!joined && !loading}}">
    <view class="join-card">
      <view class="join-icon">🏃‍♂️</view>
      <text class="join-desc">{{i.challengeDesc || '加入14天跑姿改善挑战，每天完成一项跑姿改善任务，与跑友一起进步！'}}</text>
      <button class="btn-join" bindtap="joinChallenge">
        {{i.joinChallenge || '立即加入挑战'}}
      </button>
    </view>
  </block>

  <!-- Joined state -->
  <block wx:if="{{joined}}">
    <!-- Tab switcher -->
    <view class="tab-bar">
      <view
        class="tab-item {{activeTab === 'progress' ? 'active' : ''}}"
        data-tab="progress"
        bindtap="switchTab"
      >
        <text>{{i.progressLabel || '我的进度'}}</text>
      </view>
      <view
        class="tab-item {{activeTab === 'leaderboard' ? 'active' : ''}}"
        data-tab="leaderboard"
        bindtap="switchTab"
      >
        <text>{{i.leaderboardLabel || '排行榜'}}</text>
      </view>
    </view>

    <!-- Progress Tab -->
    <view class="tab-content" wx:if="{{activeTab === 'progress'}}">
      <!-- Progress Ring Canvas -->
      <view class="progress-ring-wrap">
        <canvas
          type="2d"
          id="progressCanvas"
          class="progress-canvas"
          style="width: 440rpx; height: 440rpx;"
        ></canvas>
      </view>

      <!-- Today's check-in -->
      <view class="checkin-card">
        <view class="checkin-header">
          <text class="checkin-label">{{i.todayTask || '今日任务'}}</text>
          <text class="checkin-progress">
            {{completedDays}}/{{challengeDays}} {{i.dayLabel || '天'}}
          </text>
        </view>
        <text class="checkin-task">
          {{completedDays < 7
            ? i.taskRunDrills
            : completedDays < 14
              ? i.taskRecordVideo
              : i.taskComplete
          }}
        </text>
        <button
          class="btn-checkin {{todayCompleted ? 'done' : ''}}"
          bindtap="checkInToday"
          disabled="{{todayCompleted}}"
        >
          {{todayCompleted ? (i.checkedIn || '已打卡 ✓') : (i.checkIn || '打卡签到')}}
        </button>
      </view>

      <!-- Day dots -->
      <view class="day-dots">
        <view
          class="day-dot {{index < completedDays ? 'filled' : ''}} {{index === completedDays && !todayCompleted ? 'current' : ''}}"
          wx:for="{{challengeDays}}"
          wx:key="*this"
          wx:for-index="index"
        >
          <text>{{index + 1}}</text>
        </view>
      </view>
    </view>

    <!-- Leaderboard Tab -->
    <view class="tab-content" wx:if="{{activeTab === 'leaderboard'}}">
      <!-- My rank -->
      <view class="my-rank-card" wx:if="{{myRank !== '-'}}">
        <text class="rank-label">{{i.rank || '我的排名'}}</text>
        <text class="rank-value">#{{myRank}}</text>
      </view>

      <!-- Leaderboard list -->
      <view class="leaderboard-list">
        <view
          class="lb-item {{item.isMe ? 'is-me' : ''}}"
          wx:for="{{leaderboard}}"
          wx:key="index"
        >
          <view class="lb-rank">
            <text wx:if="{{index === 0}}">🥇</text>
            <text wx:elif="{{index === 1}}">🥈</text>
            <text wx:elif="{{index === 2}}">🥉</text>
            <text wx:else>{{index + 1}}</text>
          </view>
          <view class="lb-avatar">{{item.avatarText}}</view>
          <view class="lb-info">
            <text class="lb-name">{{item.name}}</text>
            <text class="lb-days">{{item.days}} {{i.dayLabel || '天'}}</text>
          </view>
          <view class="lb-progress">
            <view class="lb-progress-bar">
              <view class="lb-progress-fill" style="width: {{item.days / challengeDays * 100}}%"></view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- Loading -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>{{i.loading || '加载中...'}}</text>
  </view>
</view>
