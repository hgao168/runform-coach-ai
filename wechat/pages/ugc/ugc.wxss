/* pages/ugc/ugc.wxss */
/* RF-604: UGC Content Submission — List & Management */

.ugc-header {
  padding: 24rpx 0 28rpx 0;
}

/* Submission card */
.ugc-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.ugc-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.ugc-card-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.ugc-platform-badge {
  font-size: 24rpx;
  color: #00f5a0;
  font-weight: 600;
  background: rgba(0, 245, 160, 0.12);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.ugc-status-badge {
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  border: 1rpx solid;
}

.ugc-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.ugc-link-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 10rpx;
}

.ugc-link-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ugc-copy-hint {
  font-size: 24rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* Expanded note */
.ugc-note-expanded {
  padding: 14rpx 18rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
}

.ugc-note-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-right: 8rpx;
}

.ugc-note-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.5;
}

/* Collapsed note */
.ugc-note-collapsed {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}

.ugc-note-collapsed-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ugc-expand-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
  margin-left: 12rpx;
}
