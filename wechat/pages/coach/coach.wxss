/* pages/coach/coach.wxss */
/* RF-602: WeChat 教练面板 MVP */

.coach-page {
  min-height: 100vh;
  background: #0a0a0f;
  padding: 0 32rpx 24rpx;
}

/* ── Mode Switch ── */
.mode-switch {
  display: flex;
  background: rgba(255,255,255,0.04);
  border-radius: 20rpx;
  padding: 6rpx;
  margin: 24rpx 0;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255,255,255,0.4);
  transition: all 0.25s;
}

.mode-tab.active {
  background: #00f5a0;
  color: #0a0a0f;
  font-weight: 700;
}

/* ── Card ── */
.card {
  background: linear-gradient(135deg, #12121a 0%, #1a1a2e 100%);
  border: 1rpx solid rgba(0,245,160,0.1);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* ── Coach Code Card ── */
.coach-code-card {
  text-align: center;
}

.code-label {
  font-size: 26rpx;
  color: rgba(0,245,160,0.7);
  margin-bottom: 16rpx;
}

.code-display {
  background: rgba(0,245,160,0.08);
  border: 2rpx dashed rgba(0,245,160,0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
}

.code-text {
  font-size: 48rpx;
  font-weight: 800;
  font-family: monospace;
  color: #00f5a0;
  letter-spacing: 8rpx;
}

.code-placeholder {
  color: rgba(255,255,255,0.15);
}

.code-actions {
  display: flex;
  gap: 16rpx;
}

.btn-copy,
.btn-share {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0;
}

.btn-copy {
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.8);
}

.btn-copy::after {
  border: none;
}

.btn-share {
  background: #00f5a0;
  color: #0a0a0f;
}

.btn-share::after {
  border: none;
}

/* ── Dashboard ── */
.dashboard-card {
  padding-bottom: 24rpx;
}

.dashboard-grid {
  display: flex;
  margin-top: 20rpx;
}

.dash-item {
  flex: 1;
  text-align: center;
}

.dash-value {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
}

.dash-value.accent {
  color: #00f5a0;
}

.dash-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
  margin-top: 8rpx;
}

/* ── Section header ── */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.section-title .card & {
  margin-bottom: 0;
}

.refresh-link {
  font-size: 26rpx;
  color: rgba(0,245,160,0.7);
}

/* ── Student List ── */
.student-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.student-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
}

.student-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(0,245,160,0.15);
  color: #00f5a0;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.student-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.student-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.student-meta {
  display: flex;
  gap: 24rpx;
}

.student-stat {
  font-size: 22rpx;
}

.meta-label {
  color: rgba(255,255,255,0.35);
}

.meta-value {
  color: rgba(255,255,255,0.7);
  font-weight: 500;
}

.meta-value.accent {
  color: #00f5a0;
}

.student-date {
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
  flex-shrink: 0;
}

/* ── Join Card ── */
.join-card {
  padding: 20rpx 24rpx;
}

.join-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.join-input {
  flex: 1;
  height: 80rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #fff;
  font-family: monospace;
  letter-spacing: 4rpx;
}

.join-input::placeholder {
  color: rgba(255,255,255,0.2);
}

.btn-join {
  flex-shrink: 0;
  height: 80rpx;
  line-height: 80rpx;
  background: #00f5a0;
  color: #0a0a0f;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0 32rpx;
}

.btn-join::after {
  border: none;
}

.btn-join:active {
  opacity: 0.8;
}

/* ── Joined Coaches List ── */
.coach-joined-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.joined-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
}

.joined-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.joined-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.joined-code {
  font-size: 30rpx;
  font-weight: 600;
  color: #00f5a0;
  font-family: monospace;
  letter-spacing: 4rpx;
}

.joined-date {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
}

.joined-arrow {
  font-size: 36rpx;
  color: rgba(255,255,255,0.2);
  font-weight: 300;
}

/* ── Empty State ── */
.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 8rpx;
}

.empty-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
  line-height: 1.5;
}
