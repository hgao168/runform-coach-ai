<!-- pages/result/result.wxml -->
<view class="page-container">

  <!-- Overall score hero card -->
  <view class="hero-card">
    <text class="hero-label">{{i.confidence}}</text>
    <text class="hero-score" style="color: {{scoreColor}};">{{confidenceDisplay}}</text>
    <view class="progress-track" style="margin-top: 16rpx;">
      <view class="progress-fill" style="width: {{confidencePct}}%;"></view>
    </view>
    <text class="hero-summary">{{overallAssessment}}</text>
  </view>

  <!-- Form metrics -->
  <view class="card" wx:if="{{metrics.length > 0}}">
    <text class="section-title">{{i.metrics}}</text>
    <view class="metrics-grid">
      <view class="metric-item" wx:for="{{metrics}}" wx:key="index">
        <text class="metric-label">{{item.label}}</text>
        <view class="metric-bar-track">
          <view class="metric-bar-fill" style="width: {{item.pct}}%; background: {{item.color}};"></view>
        </view>
        <text class="metric-value" style="color: {{item.color}};">{{item.valueText}}</text>
      </view>
    </view>
  </view>

  <!-- Issues / Insights -->
  <view class="card" wx:if="{{insights.length > 0}}">
    <text class="section-title">⚠️ {{i.insightsTitle}}</text>
    <view wx:for="{{insights}}" wx:key="index" class="insight-item">
      <view class="insight-badge" style="background: {{item.color}}20; border-color: {{item.color}}40;">
        <text class="insight-severity" style="color: {{item.color}};">{{item.severityText}}</text>
      </view>
      <view class="insight-body">
        <text class="insight-title">{{item.title}}</text>
        <text class="insight-desc">{{item.description}}</text>
      </view>
    </view>
  </view>

  <!-- No issues -->
  <view class="card" wx:if="{{insights.length === 0}}">
    <view class="empty-good">
      <text style="font-size: 64rpx;">✅</text>
      <text class="text-mint" style="font-size: 30rpx; font-weight: 600; margin-top: 12rpx;">{{i.noIssues}}</text>
    </view>
  </view>

  <!-- Strength Focus / Exercise recommendations -->
  <view class="card card-dark strength-focus-card" wx:if="{{exercises.length > 0}}">
    <view class="sf-header">
      <text class="sf-header-icon">🏋️</text>
      <text class="section-title sf-header-title">{{i.strengthFocus}}</text>
    </view>
    <text class="sf-subtitle">{{i.strengthFocusDesc}}</text>

    <view wx:for="{{exercises}}" wx:key="index" class="exercise-card" bindtap="openExercise" data-index="{{index}}">
      <!-- Exercise header: icon + name + target issue badge -->
      <view class="ex-card-header">
        <view class="ex-icon-wrap">
          <text class="ex-icon">{{item.icon}}</text>
        </view>
        <view class="ex-title-wrap">
          <text class="ex-name">{{item.name}}</text>
          <text class="ex-target" wx:if="{{item.targetIssue}}">🎯 {{i.targetsIssue}}: {{item.targetIssue}}</text>
        </view>
        <text class="ex-arrow">→</text>
      </view>

      <!-- Description -->
      <text class="ex-desc">{{item.description}}</text>

      <!-- Sets / Reps / Frequency -->
      <view wx:if="{{item.sets || item.duration}}" class="ex-meta-row">
        <view wx:if="{{item.sets}}" class="ex-meta-chip">
          <text class="ex-meta-num">{{item.sets}}</text>
          <text class="ex-meta-label">{{i.setLabel}}</text>
          <text class="ex-meta-sep">×</text>
          <text class="ex-meta-num">{{item.reps}}</text>
          <text class="ex-meta-label">{{i.repLabel}}</text>
        </view>
        <view wx:if="{{item.duration}}" class="ex-meta-chip ex-meta-chip-alt">
          <text>⏱ {{item.duration}}</text>
        </view>
        <view wx:if="{{item.frequency_per_week}}" class="ex-meta-chip ex-meta-chip-alt">
          <text>📅 {{item.frequency_per_week}}{{i.perWeek}}</text>
        </view>
      </view>

      <!-- Video search link -->
      <view class="ex-video-link">
        <view class="ex-video-link-inner">
          <text class="ex-video-icon">🎬</text>
          <text class="ex-video-text">{{i.watchTutorial}}</text>
          <text class="ex-video-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ──────── RF-302: User Feedback Rating ──────── -->
  <view class="card feedback-card" wx:if="{{!feedbackSubmitted}}">
    <view class="feedback-header">
      <text class="section-title" style="margin-bottom: 6rpx;">{{i.feedbackTitle}}</text>
      <text class="feedback-subtitle">{{i.feedbackSubtitle}}</text>
    </view>

    <!-- Star rating -->
    <view class="star-row">
      <text
        wx:for="{{[1,2,3,4,5]}}"
        wx:key="*this"
        class="star {{item <= feedbackRating ? 'star-active' : ''}}"
        data-star="{{item}}"
        bindtap="onStarTap"
      >★</text>
    </view>

    <!-- Text comment -->
    <textarea
      class="feedback-textarea"
      placeholder="{{i.feedbackPlaceholder}}"
      placeholder-style="color: rgba(255,255,255,0.3);"
      maxlength="500"
      auto-height
      value="{{feedbackComment}}"
      bindinput="onFeedbackCommentInput"
    />

    <!-- Submit button -->
    <button
      class="btn-primary feedback-submit-btn"
      bindtap="submitFeedback"
      disabled="{{feedbackRating === 0 || feedbackSubmitting}}"
      loading="{{feedbackSubmitting}}"
    >
      {{feedbackSubmitting ? i.feedbackSubmitting : i.feedbackSubmit}}
    </button>

    <!-- Offline saved hint -->
    <view wx:if="{{feedbackSavedOffline}}" class="offline-hint">
      <text class="offline-hint-text">📡 {{i.feedbackSavedOffline}}</text>
    </view>
  </view>

  <!-- Feedback submitted confirmation -->
  <view class="card feedback-done-card" wx:if="{{feedbackSubmitted}}">
    <view class="feedback-done-content">
      <text style="font-size: 48rpx;">✅</text>
      <text class="text-mint" style="font-size: 28rpx; font-weight: 600;">{{i.feedbackSubmitted}}</text>
    </view>
  </view>

  <!-- ──────── RF-305: Voice Coach ──────── -->
  <view class="card voice-coach-card">
    <view class="voice-coach-header">
      <text class="section-title">🎙️ {{voiceCoachLabels.title}}</text>
      <view class="voice-coach-status-badge" wx:if="{{voiceState === 'playing'}}">
        <text class="voice-status-text playing">{{voiceCoachLabels.playing}}</text>
      </view>
      <view class="voice-coach-status-badge" wx:elif="{{voiceState === 'paused'}}">
        <text class="voice-status-text paused">{{voiceCoachLabels.paused}}</text>
      </view>
      <view class="voice-coach-status-badge" wx:elif="{{voiceState === 'stopped' && voiceQueueLength === 0}}">
        <text class="voice-status-text stopped">{{voiceCoachLabels.stopped}}</text>
      </view>
    </view>

    <view class="voice-coach-controls" wx:if="{{voiceEnabled}}">
      <!-- Play/Pause -->
      <button
        class="voice-btn voice-btn-play"
        bindtap="onVoiceCoachToggle"
        disabled="{{voiceMuted}}"
      >
        <text wx:if="{{voiceState === 'playing'}}">⏸️ {{voiceCoachLabels.playing}}</text>
        <text wx:elif="{{voiceState === 'paused'}}">▶️ {{voiceCoachLabels.paused}}</text>
        <text wx:else>▶️ {{voiceCoachLabels.play}}</text>
      </button>

      <!-- Stop -->
      <button
        class="voice-btn voice-btn-stop"
        bindtap="onVoiceCoachStop"
        disabled="{{voiceState === 'stopped'}}"
      >
        ⏹️ {{voiceCoachLabels.stop}}
      </button>

      <!-- Mute toggle -->
      <button
        class="voice-btn voice-btn-mute"
        bindtap="onVoiceCoachMuteToggle"
      >
        <text wx:if="{{voiceMuted}}">🔇 {{voiceCoachLabels.unmute}}</text>
        <text wx:else>🔊 {{voiceCoachLabels.mute}}</text>
      </button>
    </view>

    <!-- Disabled state -->
    <view class="voice-coach-disabled" wx:if="{{!voiceEnabled}}">
      <text class="voice-disabled-text">🔕 {{voiceCoachLabels.disabled}}</text>
      <button class="voice-btn voice-btn-enable" bindtap="onVoiceCoachEnableToggle">
        {{voiceCoachLabels.enable}}
      </button>
    </view>

    <!-- No audio files hint (dev mode) -->
    <view class="voice-coach-no-audio-hint">
      <text class="voice-no-audio-text">ℹ️ {{voiceCoachLabels.noAudio}}</text>
    </view>
  </view>

  <!-- Action buttons -->
  <view class="action-section">
    <button class="btn-secondary full-btn" bindtap="goCompare">{{i.compareWithElite}}</button>

    <!-- RF-1010: Weekly insight entry -->
    <button class="btn-mint-outline full-btn" style="margin-top: 20rpx;" bindtap="goInsight">
      📊 {{isZh ? '周训练洞察' : 'Weekly Insight'}}
    </button>

    <!-- RF-304: Share button (uses WeChat native share) -->
    <button class="btn-mint-outline full-btn" style="margin-top: 20rpx;" open-type="share">
      📤 {{i.shareResult}}
    </button>

    <!-- RF-913: Save share image to album -->
    <button class="btn-secondary full-btn" style="margin-top: 20rpx;" bindtap="saveShareToAlbum">
      🖼️ {{i.saveToAlbum}}
    </button>

    <!-- RF-604: UGC Content Submission -->
    <button class="btn-mint-outline full-btn" style="margin-top: 20rpx;" bindtap="onUgcSubmitBtn">
      {{i.ugcSubmitBtn}}
    </button>
  </view>

  <!-- RF-604: UGC Submission Modal -->
  <view wx:if="{{ugcModalVisible}}" class="ugc-modal-backdrop" bindtap="onUgcModalClose">
    <view class="ugc-modal" catchtap="onUgcModalPrevent">
      <view class="ugc-modal-header">
        <text class="ugc-modal-title">{{i.ugcModalTitle}}</text>
        <text class="ugc-modal-close" bindtap="onUgcModalClose">✕</text>
      </view>

      <!-- Platform selector -->
      <view class="ugc-section">
        <text class="ugc-label">{{i.ugcPlatformLabel}}</text>
        <view class="ugc-platform-row">
          <view
            wx:for="{{ugcPlatforms}}"
            wx:key="key"
            class="ugc-platform-chip {{ugcPlatform === item.key ? 'ugc-platform-chip-active' : ''}}"
            data-key="{{item.key}}"
            bindtap="onUgcPlatformSelect"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- Link input -->
      <view class="ugc-section">
        <text class="ugc-label">{{i.ugcLinkLabel}}</text>
        <input
          class="ugc-input"
          placeholder="{{i.ugcLinkPlaceholder}}"
          placeholder-style="color: rgba(255,255,255,0.3);"
          value="{{ugcLink}}"
          bindinput="onUgcLinkInput"
        />
      </view>

      <!-- Note input -->
      <view class="ugc-section">
        <text class="ugc-label">{{i.ugcNoteLabel}}</text>
        <textarea
          class="ugc-textarea"
          placeholder="{{i.ugcNotePlaceholder}}"
          placeholder-style="color: rgba(255,255,255,0.3);"
          maxlength="300"
          auto-height
          value="{{ugcNote}}"
          bindinput="onUgcNoteInput"
        />
      </view>

      <!-- Submit button -->
      <button
        class="btn-primary ugc-submit-btn"
        bindtap="submitUgc"
        loading="{{ugcSubmitting}}"
        disabled="{{ugcSubmitting || !ugcPlatform || !ugcLink}}"
      >
        {{ugcSubmitting ? i.ugcSubmitting : i.ugcSubmitAction}}
      </button>
    </view>
  </view>

  <!-- RF-963: Rewarded video ad -->
  <view class="card ad-card" wx:if="{{rewardedAdAvailable}}">
    <view class="ad-header">
      <text class="ad-icon">🎬</text>
      <text class="ad-title">{{i.adWatchTitle}}</text>
    </view>
    <text class="ad-desc">{{i.adWatchDesc}}</text>
    <button class="btn-ad" bindtap="showRewardedAd">
      ▶️ {{i.adWatchButton}}
    </button>
  </view>

  <!-- RF-304: Hidden canvas for share image generation (2D Canvas) -->
  <canvas
    type="2d"
    id="shareCanvas"
    style="position: fixed; left: -9999rpx; top: -9999rpx; width: 600rpx; height: 800rpx;"
  />

</view>
