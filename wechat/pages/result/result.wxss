/* pages/result/result.wxss */

.hero-card {
  background: linear-gradient(135deg, rgba(0,245,160,0.12), rgba(0,212,255,0.08));
  border: 1rpx solid rgba(0,245,160,0.25);
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.56);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}

.hero-score {
  font-size: 100rpx;
  font-weight: 800;
  letter-spacing: -2rpx;
  line-height: 1;
}

.hero-summary {
  font-size: 28rpx;
  color: rgba(255,255,255,0.82);
  text-align: center;
  margin-top: 20rpx;
  line-height: 1.6;
}

.metrics-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 16rpx;
}

.metric-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.metric-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.72);
  width: 180rpx;
  flex-shrink: 0;
}

.metric-bar-track {
  flex: 1;
  height: 10rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 5rpx;
  overflow: hidden;
}

.metric-bar-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.4s;
}

.metric-value {
  font-size: 26rpx;
  font-weight: 600;
  width: 64rpx;
  text-align: right;
}

.insight-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}

.insight-item:first-of-type {
  border-top: none;
  margin-top: 12rpx;
  padding-top: 0;
}

.insight-badge {
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  border: 1rpx solid transparent;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.insight-severity {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.insight-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.insight-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.92);
}

.insight-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.62);
  line-height: 1.5;
}

/* ──────── Strength Focus (iOS-style exercise cards) ──────── */

.strength-focus-card {
  /* Uses card-dark from global — darker background */
}

.sf-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.sf-header-icon {
  font-size: 36rpx;
}

.sf-header-title {
  margin-bottom: 0;
}

.sf-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.42);
  line-height: 1.5;
  margin-bottom: 24rpx;
  display: block;
}

/* Each issue block inside strength focus */
.sf-issue-block {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.sf-issue-block:first-of-type {
  margin-top: 0;
  padding-top: 0;
  border-top: none;
}

/* Issue header — same layout as old insight-item */
.sf-issue-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

/* Exercises container under each issue */
.sf-exercises {
  padding-left: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* Exercise category label */
.ex-category {
  font-size: 22rpx;
  color: rgba(0, 245, 160, 0.5);
  line-height: 1.3;
}

/* Exercise card within strength focus */
.exercise-card {
  margin-top: 20rpx;
  padding: 24rpx;
  background: rgba(0, 245, 160, 0.06);
  border: 1rpx solid rgba(0, 245, 160, 0.12);
  border-radius: 20rpx;
  transition: background 0.15s;
}

.exercise-card:active {
  background: rgba(0, 245, 160, 0.12);
}

.ex-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.ex-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: rgba(0, 245, 160, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ex-icon {
  font-size: 28rpx;
}

.ex-title-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.ex-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.ex-target {
  font-size: 22rpx;
  color: rgba(255, 159, 48, 0.85);
  line-height: 1.3;
}

.ex-arrow {
  font-size: 28rpx;
  color: rgba(0, 245, 160, 0.5);
  flex-shrink: 0;
}

.ex-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.62);
  line-height: 1.55;
  margin-bottom: 16rpx;
  display: block;
}

/* Sets/reps/frequency meta row */
.ex-meta-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.ex-meta-chip {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 16rpx;
  background: rgba(0, 245, 160, 0.08);
  border: 1rpx solid rgba(0, 245, 160, 0.15);
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #00f5a0;
}

.ex-meta-chip-alt {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.6);
}

.ex-meta-num {
  font-weight: 700;
  color: #00f5a0;
}

.ex-meta-label {
  color: rgba(255, 255, 255, 0.5);
}

.ex-meta-sep {
  color: rgba(255, 255, 255, 0.3);
  margin: 0 2rpx;
}

/* Video search link — iOS style pill */
.ex-video-link {
  display: flex;
  justify-content: flex-end;
}

.ex-video-link-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: rgba(0, 212, 255, 0.1);
  border: 1rpx solid rgba(0, 212, 255, 0.2);
  border-radius: 24rpx;
}

.ex-video-icon {
  font-size: 22rpx;
}

.ex-video-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #00d4ff;
}

.ex-video-arrow {
  font-size: 26rpx;
  font-weight: 700;
  color: #00d4ff;
  margin-left: 2rpx;
}

.empty-good {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  gap: 8rpx;
}

.action-section {
  padding: 8rpx 0 40rpx 0;
}

/* ──────── RF-302: Feedback ──────── */

.feedback-card {
  /* inherits card style */
}

.feedback-header {
  margin-bottom: 16rpx;
}

.feedback-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
  line-height: 1.5;
}

/* Star rating row */
.star-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 20rpx;
  justify-content: center;
}

.star {
  font-size: 56rpx;
  color: rgba(255,255,255,0.16);
  transition: color 0.2s, transform 0.15s;
}

.star-active {
  color: #ff9f30;
  text-shadow: 0 0 16rpx rgba(255,159,48,0.4);
}

.star:active {
  transform: scale(1.2);
}

/* Feedback textarea */
.feedback-textarea {
  width: 100%;
  min-height: 120rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #ffffff;
  box-sizing: border-box;
  line-height: 1.6;
}

.feedback-submit-btn {
  margin-top: 16rpx;
}

/* Offline hint */
.offline-hint {
  margin-top: 14rpx;
  background: rgba(255,159,48,0.12);
  border: 1rpx solid rgba(255,159,48,0.25);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
}

.offline-hint-text {
  font-size: 24rpx;
  color: #ff9f30;
}

/* Feedback done */
.feedback-done-card {
  /* inherits card */
}

.feedback-done-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
}

/* ──────── RF-304: Share button ──────── */

/* Share button uses open-type="share" — styling inherited from btn-mint-outline */

/* ──────── RF-305: Voice Coach ──────── */

.voice-coach-card {
  /* inherits card */
}

.voice-coach-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.voice-coach-status-badge {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.voice-coach-status-badge .playing {
  color: #00f5a0;
}

.voice-coach-status-badge .paused {
  color: #ff9f30;
}

.voice-coach-status-badge .stopped {
  color: rgba(255,255,255,0.4);
}

.voice-coach-controls {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.voice-btn {
  flex: 1;
  min-width: 140rpx;
  height: 72rpx;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.voice-btn::after {
  border: none;
}

.voice-btn[disabled] {
  opacity: 0.35;
}

.voice-btn-play {
  background: rgba(0,245,160,0.12);
  border-color: rgba(0,245,160,0.25);
  color: #00f5a0;
}

.voice-btn-stop {
  background: rgba(255,71,87,0.1);
  border-color: rgba(255,71,87,0.2);
  color: #ff4757;
}

.voice-btn-mute {
  background: rgba(255,159,48,0.1);
  border-color: rgba(255,159,48,0.2);
  color: #ff9f30;
}

.voice-coach-disabled {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.voice-disabled-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.35);
}

.voice-btn-enable {
  background: rgba(0,212,255,0.12);
  border-color: rgba(0,212,255,0.25);
  color: #00d4ff;
  height: 64rpx;
  padding: 0 32rpx;
  font-size: 26rpx;
  border-radius: 16rpx;
}

.voice-coach-no-audio-hint {
  margin-top: 16rpx;
  padding: 12rpx 20rpx;
  background: rgba(0,212,255,0.06);
  border: 1rpx solid rgba(0,212,255,0.12);
  border-radius: 12rpx;
}

.voice-no-audio-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
  line-height: 1.5;
}

.full-btn {
  width: 100%;
  height: 96rpx;
  font-size: 30rpx;
  border-radius: 28rpx;
}

/* ──────── RF-963: Rewarded video ad ──────── */

.ad-card {
  text-align: center;
}

.ad-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.ad-icon {
  font-size: 36rpx;
}

.ad-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
}

.ad-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
  line-height: 1.5;
  display: block;
  margin-bottom: 20rpx;
}

.btn-ad {
  width: 100%;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(255,159,48,0.18), rgba(255,71,87,0.12));
  color: #ff9f30;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255,159,48,0.3);
  box-sizing: border-box;
}

.btn-ad::after {
  border: none;
}

/* ──────── RF-604: UGC Submission Modal ──────── */

.ugc-modal-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.ugc-modal {
  width: 100%;
  max-height: 85vh;
  background: #14141e;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 36rpx 32rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.ugc-modal-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.ugc-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.ugc-modal-close {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 8rpx 16rpx;
}

.ugc-section {
  margin-bottom: 24rpx;
}

.ugc-label {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.ugc-platform-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.ugc-platform-chip {
  padding: 16rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  transition: all 0.2s;
}

.ugc-platform-chip-active {
  background: rgba(0, 245, 160, 0.15);
  border-color: #00f5a0;
  color: #00f5a0;
  font-weight: 600;
}

.ugc-input {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #ffffff;
  box-sizing: border-box;
}

.ugc-textarea {
  width: 100%;
  min-height: 120rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #ffffff;
  box-sizing: border-box;
  line-height: 1.5;
}

.ugc-submit-btn {
  margin-top: 8rpx;
}
