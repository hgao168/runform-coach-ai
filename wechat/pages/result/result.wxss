/* pages/result/result.wxss */

.hero-card {
  background: linear-gradient(135deg, rgba(0,245,160,0.12), rgba(0,212,255,0.08));
  border: 1rpx solid rgba(0,245,160,0.25);
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.56);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}

.hero-score {
  font-size: 100rpx;
  font-weight: 800;
  letter-spacing: -2rpx;
  line-height: 1;
}

.hero-summary {
  font-size: 28rpx;
  color: rgba(255,255,255,0.82);
  text-align: center;
  margin-top: 20rpx;
  line-height: 1.6;
}

.metrics-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 16rpx;
}

.metric-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.metric-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.72);
  width: 180rpx;
  flex-shrink: 0;
}

.metric-bar-track {
  flex: 1;
  height: 10rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 5rpx;
  overflow: hidden;
}

.metric-bar-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.4s;
}

.metric-value {
  font-size: 26rpx;
  font-weight: 600;
  width: 64rpx;
  text-align: right;
}

.insight-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}

.insight-item:first-of-type {
  border-top: none;
  margin-top: 12rpx;
  padding-top: 0;
}

.insight-badge {
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  border: 1rpx solid transparent;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.insight-severity {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.insight-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.insight-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.92);
}

.insight-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.62);
  line-height: 1.5;
}

.exercise-item {
  margin-top: 20rpx;
  padding: 24rpx;
  background: rgba(0,245,160,0.05);
  border: 1rpx solid rgba(0,245,160,0.15);
  border-radius: 20rpx;
}

.exercise-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.exercise-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #00f5a0;
}

.exercise-link-icon {
  font-size: 28rpx;
}

.exercise-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  line-height: 1.5;
}

.exercise-meta {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.meta-chip {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.08);
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

.empty-good {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  gap: 8rpx;
}

.action-section {
  padding: 8rpx 0 40rpx 0;
}

/* ──────── RF-302: Feedback ──────── */

.feedback-card {
  /* inherits card style */
}

.feedback-header {
  margin-bottom: 16rpx;
}

.feedback-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
  line-height: 1.5;
}

/* Star rating row */
.star-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 20rpx;
  justify-content: center;
}

.star {
  font-size: 56rpx;
  color: rgba(255,255,255,0.16);
  transition: color 0.2s, transform 0.15s;
}

.star-active {
  color: #ff9f30;
  text-shadow: 0 0 16rpx rgba(255,159,48,0.4);
}

.star:active {
  transform: scale(1.2);
}

/* Feedback textarea */
.feedback-textarea {
  width: 100%;
  min-height: 120rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #ffffff;
  box-sizing: border-box;
  line-height: 1.6;
}

.feedback-submit-btn {
  margin-top: 16rpx;
}

/* Offline hint */
.offline-hint {
  margin-top: 14rpx;
  background: rgba(255,159,48,0.12);
  border: 1rpx solid rgba(255,159,48,0.25);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
}

.offline-hint-text {
  font-size: 24rpx;
  color: #ff9f30;
}

/* Feedback done */
.feedback-done-card {
  /* inherits card */
}

.feedback-done-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
}

/* ──────── RF-304: Share button ──────── */

/* Share button uses open-type="share" — styling inherited from btn-mint-outline */

.full-btn {
  width: 100%;
  height: 96rpx;
  font-size: 30rpx;
  border-radius: 28rpx;
}
