/* pages/cadence/cadence.wxss */

/* ── Header ── */
.header-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 24rpx;
}

.icon-bubble {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(0, 245, 160, 0.18), rgba(0, 212, 255, 0.18));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.header-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

/* ── 步频主显示区 ── */
.cadence-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 36rpx;
}

.cadence-display {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.cadence-number {
  font-size: 96rpx;
  font-weight: 800;
  color: #00f5a0;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.cadence-unit {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(0, 245, 160, 0.6);
}

/* ── 检测指示器 ── */
.detecting-indicator {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.dot-pulse {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #00f5a0;
  animation: dotPulse 1.2s ease-in-out infinite;
}

@keyframes dotPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.35; transform: scale(1.6); }
}

.detecting-text {
  font-size: 26rpx;
  color: rgba(0, 245, 160, 0.7);
}

/* ── 数据网格 ── */
.data-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 24rpx;
}

.data-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.data-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  font-variant-numeric: tabular-nums;
}

.data-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.48);
}

/* ── 置信度进度条 ── */
.confidence-bar {
  width: 100%;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 6rpx;
  overflow: hidden;
}

.confidence-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #00f5a0, #00d4ff);
  transition: width 0.3s ease;
}

/* ── 操作按钮 ── */
.action-area {
  margin-bottom: 24rpx;
}

.start-btn {
  width: 100%;
  height: 100rpx;
  font-size: 34rpx;
}

.stop-btn {
  width: 100%;
  height: 100rpx;
  font-size: 34rpx;
}

/* ── 错误卡片 ── */
.error-card {
  background: rgba(255, 80, 80, 0.12);
  border: 1rpx solid rgba(255, 80, 80, 0.3);
}

.error-text {
  font-size: 26rpx;
  color: #ff6b6b;
  line-height: 1.6;
}

/* ── 结果卡片 ── */
.result-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.result-key {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.56);
}

.result-val {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}