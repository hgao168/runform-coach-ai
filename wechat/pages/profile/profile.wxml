<!-- pages/profile/profile.wxml -->
<view class="page-container">

  <!-- Avatar hero -->
  <view class="avatar-section">
    <view class="avatar-circle">
      <text class="avatar-initial">{{avatarInitial}}</text>
    </view>
    <text class="profile-name">{{displayName}}</text>
    <text class="profile-level-badge level-{{form.level}}">{{levelLabel}}</text>
  </view>

  <!-- Form card -->
  <view class="card">
    <text class="section-title">基本信息</text>

    <view class="field-row">
      <text class="field-label">{{i.firstName}}</text>
      <input class="input-field" value="{{form.firstName}}" placeholder="名字" bindinput="onInput" data-key="firstName" />
    </view>

    <view class="field-row">
      <text class="field-label">{{i.lastName}}</text>
      <input class="input-field" value="{{form.lastName}}" placeholder="姓氏" bindinput="onInput" data-key="lastName" />
    </view>

    <view class="field-row">
      <text class="field-label">{{i.level}}</text>
      <view class="level-chips">
        <view
          wx:for="{{levelOptions}}" wx:key="key"
          class="chip {{form.level === item.key ? 'chip-active' : ''}}"
          bindtap="selectLevel"
          data-key="{{item.key}}"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="field-row">
      <text class="field-label">{{i.weeklyKmLabel}}</text>
      <view class="km-row">
        <slider
          class="km-slider"
          min="5" max="150" step="5"
          value="{{form.weeklyMileageKm}}"
          activeColor="#00f5a0"
          backgroundColor="rgba(255,255,255,0.12)"
          bindchange="onKmChange"
        />
        <text class="text-mint km-value">{{form.weeklyMileageKm}} km</text>
      </view>
    </view>

    <view class="field-row">
      <text class="field-label">{{i.runDaysPerWeek}}</text>
      <view class="stepper-row">
        <view class="stepper-btn" bindtap="decrementDays">－</view>
        <text class="stepper-value">{{form.runningDaysPerWeek}}</text>
        <view class="stepper-btn" bindtap="incrementDays">＋</view>
      </view>
    </view>

    <view class="field-row">
      <text class="field-label">{{i.targetLabel}}</text>
      <view class="target-chips">
        <view
          wx:for="{{goalOptions}}" wx:key="key"
          class="chip {{form.target === item.key ? 'chip-active' : ''}}"
          bindtap="selectTarget"
          data-key="{{item.key}}"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="field-row" style="flex-direction: column; align-items: flex-start;">
      <text class="field-label" style="margin-bottom: 12rpx;">{{i.injuryNote}}</text>
      <textarea
        class="input-field textarea"
        value="{{form.injuryNote}}"
        placeholder="如有伤病或疼痛，在此说明…"
        bindinput="onInput"
        data-key="injuryNote"
        auto-height="{{true}}"
        maxlength="300"
      />
    </view>

  </view>

  <button class="btn-primary full-btn" bindtap="saveProfile">{{i.saveProfile}}</button>
  <view style="height: 60rpx;"></view>

</view>
