/* pages/profile/profile.wxss */

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
  gap: 12rpx;
}

.avatar-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #00f5a0, #00d4ff);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-image-wrap {
  overflow: hidden;
  background: rgba(255,255,255,0.08);
}

.avatar-image {
  width: 120rpx;
  height: 120rpx;
}

.avatar-initial {
  font-size: 56rpx;
  font-weight: 800;
  color: #0a0a0f;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.92);
}

.profile-level-badge {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1px;
  padding: 6rpx 20rpx;
  border-radius: 12rpx;
  text-transform: uppercase;
}

.level-beginner { background: rgba(0,245,160,0.18); color: #00f5a0; }
.level-intermediate { background: rgba(0,212,255,0.18); color: #00d4ff; }
.level-advanced { background: rgba(255,159,48,0.18); color: #ff9f30; }

.auth-card {
  margin-bottom: 24rpx;
}

.auth-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.auth-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: rgba(255,255,255,0.48);
}

.auth-status {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.56);
  font-size: 22rpx;
  font-weight: 700;
}

.auth-status-on {
  background: rgba(0,245,160,0.16);
  color: #00f5a0;
}

.auth-linked {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.04);
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 20rpx;
}

.auth-linked-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

.auth-linked-value {
  font-size: 24rpx;
  color: rgba(255,255,255,0.86);
  font-weight: 700;
}

.btn-wechat-login,
.btn-avatar {
  width: 100%;
  height: 88rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 22rpx;
}

.btn-wechat-login {
  background: #07c160;
  color: #fff;
}

.btn-wechat-login::after,
.btn-avatar::after {
  border: none;
}

.btn-avatar {
  background: rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.82);
  border: 1rpx solid rgba(255,255,255,0.12);
}

.field-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
  gap: 16rpx;
  flex-wrap: wrap;
}

.field-row:last-child { border-bottom: none; }

.field-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.72);
  flex-shrink: 0;
  min-width: 160rpx;
}

.level-chips,
.target-chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  padding: 10rpx 24rpx;
  border-radius: 14rpx;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
  font-size: 26rpx;
  color: rgba(255,255,255,0.72);
}

.chip-active {
  background: rgba(0,245,160,0.18);
  border-color: rgba(0,245,160,0.5);
  color: #00f5a0;
  font-weight: 700;
}

.km-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.km-slider { flex: 1; }

.km-value {
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
  min-width: 80rpx;
  text-align: right;
}

.stepper-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.stepper-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #00f5a0;
}

.stepper-value {
  font-size: 36rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.92);
  min-width: 40rpx;
  text-align: center;
}

.textarea {
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
}

.full-btn {
  width: 100%;
  height: 96rpx;
  font-size: 30rpx;
  border-radius: 28rpx;
  margin-top: 32rpx;
}
